// Proxy all /api/* requests to worker via Service binding
export async function onRequest({ request, platform }: { request: Request; platform: any }) {
  const url = new URL(request.url);
  const path = url.pathname;

  // Only proxy /api/* requests
  if (!path.startsWith('/api/')) {
    return new Response('Not Found', { status: 404 });
  }

  // Use Service binding if available
  if (platform?.env?.GLIANA_PAY_WORKER) {
    try {
      // Clone request to read body (streams can only be read once)
      const clonedReq = request.clone();
      const body = (request.method === 'POST' || request.method === 'PUT')
        ? await clonedReq.text()
        : undefined;

      // Create new request for worker
      const workerUrl = new URL(path, url.origin);
      const workerReq = new Request(workerUrl.toString(), {
        method: request.method,
        headers: request.headers,
        body,
      });

      const response = await platform.env.WORKER.fetch(workerReq);
      return response;
    } catch (e) {
      console.error('Worker proxy error:', e);
      return new Response('Worker Error', { status: 500 });
    }
  }

  return new Response('Service binding not configured', { status: 500 });
}
